# ━━━ AI客户分析助手 · 生产环境配置 ━━━
# 复制此文件为 .env 并填入真实值，然后启动 docker compose up -d

# ━━ 数据库 (MySQL) ━━
DB_ROOT_PASSWORD=请修改为强密码
DB_USER=customer_analysis
DB_PASSWORD=请修改为强密码
DB_NAME=customer_analysis

# ━━ LLM ━━
LLM_PROVIDER=deepseek
DEEPSEEK_API_KEY=sk-你的DeepSeek密钥
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
DEEPSEEK_MODEL=deepseek-chat

# ━━ 搜索（DuckDuckGo 免费，留空即可）━━
# SERPAPI_API_KEY=

# ━━ 前端 ━━
CORS_ORIGIN=http://你的服务器IP或域名
